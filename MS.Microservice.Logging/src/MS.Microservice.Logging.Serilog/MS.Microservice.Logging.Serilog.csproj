<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>MS.Microservice.Logging.Serilog</PackageId>
    <Title>MS.Microservice Logging Serilog</Title>
    <Description>Serilog provider integration and enrichers for MS.Microservice logging.</Description>
    <Authors>MS.Microservice</Authors>
    <PackageTags>logging;serilog;observability</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" />
    <PackageReference Include="Serilog" />
    <PackageReference Include="Serilog.Extensions.Hosting" />
    <PackageReference Include="Serilog.Settings.Configuration" />
    <PackageReference Include="Serilog.Sinks.Console" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\MS.Microservice.Logging.Core\MS.Microservice.Logging.Core.csproj" />
  </ItemGroup>
</Project>