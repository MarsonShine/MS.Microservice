<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true"
      internalLogLevel="Warn"
      internalLogFile="${basedir}/logs/internal-nlog.log">

  <!--
    MS.Microservice.Logging.NLog — sample configuration
    ------------------------------------------------------------------
    Custom layout renderers provided by this package:
      ${requestId}           — from request header (default: "requestId")
      ${platformId}          — from request header (default: "platformId")
      ${userflag}            — from request header (default: "userflag")
      ${RequestDuration}     — request elapsed time in ms (e.g. "12ms")
      ${NetAddress}          — configured network address (via MsNLogOptions)
      ${hours} / ${year} / ${month}  — log event timestamp parts

    All request-context renderers read from the ambient RequestLogScope,
    which is populated by MsRequestLoggingMiddleware (ASP.NET Core) or
    manually via RequestLogScope.Push() (Worker/Console).

    This file is optional. If missing, the provider auto-configures a
    console target with a sensible default layout.
  -->

  <!-- Global variables for centralized path management -->
  <variable name="logDir" value="${basedir}/logs" />

  <targets async="true" queueLimit="10000" overflowAction="Discard">

    <!-- Console (development observation) -->
    <target xsi:type="Console" name="console" detectConsoleAvailable="true"
            layout="${longdate} | ${uppercase:${level}} | ${logger} | ${aspnet-request-method} ${aspnet-request-url} | rid=${requestId} pid=${platformId} uflag=${userflag} | dur=${RequestDuration} | ${message} ${onexception:inner=${exception:format=ToString}}" />

    <!-- File (production persistence)
         NLog 6+: keepFileOpen="true" for best single-process throughput.
         For multi-process write to the same file, use keepFileOpen="false".
    -->
    <target xsi:type="File" name="file"
            fileName="${logDir}/app-${shortdate}-${hours}.log"
            keepFileOpen="true"
            encoding="utf-8"
            archiveEvery="Day"
            archiveNumbering="Rolling"
            maxArchiveFiles="14"
            archiveAboveSize="104857600">
      <layout>
        ${longdate} | ${uppercase:${level}} | ${logger} | ${aspnet-request-method} ${aspnet-request-url} | rid=${requestId} pid=${platformId} uflag=${userflag} | dur=${RequestDuration} | msg=${message} ${onexception:inner=${exception:format=ToString}}
      </layout>
    </target>

    <!-- Network forwarding (uncomment and add NLog.Targets.Network NuGet if needed)
    <target xsi:type="Network" name="net"
            address="${NetAddress}"
            keepAlive="true"
            newLine="true">
      <layout>
        ${longdate}|${uppercase:${level}}|${logger}|rid=${requestId}|pid=${platformId}|uflag=${userflag}|dur=${RequestDuration}|${message}${onexception:inner=|${exception:format=ToString}}
      </layout>
    </target>
    -->

  </targets>

  <rules>
    <logger name="*" minlevel="Info" writeTo="console" />
    <logger name="*" minlevel="Info" writeTo="file" />

    <!-- Raise Microsoft.* noise to Warning -->
    <logger name="Microsoft.*" minlevel="Warn" writeTo="console" final="true" />
    <logger name="Microsoft.*" minlevel="Warn" writeTo="file" final="true" />

    <!-- Uncomment when network target is enabled above -->
    <!-- <logger name="*" minlevel="Warn" writeTo="net" /> -->
  </rules>

</nlog>
